# Copiar a .env.local (no commitear). Valores de ejemplo para Docker: infra/docker-compose.yml
DATABASE_URL="postgresql://awf:awf@localhost:5432/awf_dev?schema=public"
# Secreto para firmar cookies de sesión (generar cadena larga aleatoria en prod)
SESSION_SECRET="dev-change-me-use-openssl-rand-hex-32"
# Opcional: Vercel Blob (publish/descarga en prod o dev con token real)
BLOB_READ_WRITE_TOKEN=
# Opcional local: Redis de docker-compose (rate limit); si vacío, rate limit deshabilitado
REDIS_URL="redis://localhost:6379"
# Opcional prod: Upstash (alternativa a REDIS_URL)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Cron interno (Fase 17)
CRON_SECRET=
# Base URL pública (opcional, redirects Blob; obligatoria en Vercel para alinear URLs del device login CLI con el registry)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Tamaño máximo del .tgz en POST /api/v1/artifacts/.../versions (bytes). Predeterminado: 50 MiB
# AWF_MAX_TARBALL_BYTES=52428800
# Seed opcional: segundo usuario admin (por defecto dev@draweb.cloud). Sin SEED_DEV_PASSWORD no se crea/actualiza.
# SEED_DEV_EMAIL=dev@draweb.cloud
# SEED_DEV_PASSWORD=

# Firebase (configuración pública del proyecto)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
